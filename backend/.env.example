# Agent private key (Secp256k1 hot wallet) — NEVER commit the real .env
AGENT_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Uniswap Trade API key — get from https://developers.uniswap.org/
UNISWAP_API_KEY=your_api_key_here

# RPC URLs
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BASE_RPC_URL=https://mainnet.base.org

# Target chain for testing
CHAIN_ID=11155111
